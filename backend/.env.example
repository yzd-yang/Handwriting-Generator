# 环境变量示例文件
# 复制此文件为 .env 并填写实际值（.env 不入库）

# ── Sentry 错误监控 ─────────────────────────────
# 留空则禁用 Sentry 上报
SENTRY_DSN=

# Sentry traces 采样率（0.0-1.0）
SENTRY_TRACES_SAMPLE_RATE=0.1

# ── 安全密钥 ──────────────────────────────────
# 当前未启用用户认证，留空即可
SECRET_KEY=

# ── 字体资源路径 ─────────────────────────────
FONT_ASSETS_DIR=./font_assets
FONT_ASSETS_BUNDLED_DIR=./font_assets

# ── 用户认证（已禁用）────────────────────────
ENABLE_USER_AUTH=false

# ── MySQL（已禁用）──────────────────────────
MYSQL_HOST=db

# ── 日志级别 ──────────────────────────────────
# DEBUG / INFO / WARNING / ERROR
LOG_LEVEL=INFO

# ── 上传大小限制（MB）────────────────────────
MAX_UPLOAD_MB=20

# ── CORS 允许域名（逗号分隔）───────────────
# 生产环境必须配置真实域名
CORS_ORIGINS=http://localhost:5173,http://localhost:2345
